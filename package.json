{
  "name": "murcha",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "MURCHA — universal sklad boshqaruvi va B2B zakaz platformasi",
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm -r --if-present run test",
    "db:generate": "dotenv -e .env -- pnpm --filter @murcha/api db:generate",
    "db:validate": "dotenv -e .env -- pnpm --filter @murcha/api db:validate",
    "db:migrate": "dotenv -e .env -- pnpm --filter @murcha/api db:migrate",
    "db:seed": "dotenv -e .env -- pnpm --filter @murcha/api db:seed",
    "db:rls": "dotenv -e .env -- pnpm --filter @murcha/api exec prisma db execute --file prisma/rls.sql --schema prisma/schema.prisma",
    "db:immutable": "dotenv -e .env -- pnpm --filter @murcha/api exec prisma db execute --file prisma/immutable.sql --schema prisma/schema.prisma"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsdoc": "^50.6.1",
    "eslint-plugin-vue": "^10.9.2",
    "prettier": "^3.4.2",
    "vue-eslint-parser": "^10.4.1"
  }
}
