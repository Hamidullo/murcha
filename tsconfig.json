{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "strict": false,
    "skipLibCheck": true
  },
  "include": ["apps/**/*.js", "packages/**/*.js"],
  "exclude": ["**/node_modules", "**/dist"]
}
