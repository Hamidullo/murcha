# Docker Compose va API uchun muhit o'zgaruvchilari.
# Nusxa oling: cp .env.example .env

# --- PostgreSQL ---
POSTGRES_DB=murcha
POSTGRES_USER=murcha
POSTGRES_PASSWORD=murcha
POSTGRES_PORT=5432
# Prisma shu URL'dan foydalanadi (Faza 0 Task 3)
DATABASE_URL=postgresql://murcha:murcha@postgres:5432/murcha?schema=public

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- MinIO (S3-compatible) ---
MINIO_ROOT_USER=murcha
MINIO_ROOT_PASSWORD=murcha123
MINIO_BUCKET=murcha
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- API ---
API_PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# --- Auth (Faza 1) ---
# Kamida 32 belgili tasodifiy satr: openssl rand -hex 32
JWT_ACCESS_SECRET=dev-only-change-me
JWT_ACCESS_EXPIRES_IN=15m
# Refresh token cookie — production'da .murcha.uz (app./shop. subdomenlar uchun umumiy)
COOKIE_DOMAIN=
REFRESH_TOKEN_TTL_DAYS=30

# --- Sentry (ixtiyoriy — bo'sh bo'lsa o'chiq, self-hosted GlitchTip ham shu DSN) ---
SENTRY_DSN=
