# Docker Compose va API uchun muhit o'zgaruvchilari.
# Nusxa oling: cp .env.example .env

# --- PostgreSQL ---
POSTGRES_DB=murcha
POSTGRES_USER=murcha
POSTGRES_PASSWORD=murcha
POSTGRES_PORT=5432

# --- DB rollari (Faza 13 — RLS) ---
# Postgres'da jadval EGASI va superuser RLS policy'larni chetlab o'tadi.
# Shuning uchun ikkita alohida rol ishlatiladi (prisma/roles.sql):
#
#   DATABASE_URL       — `murcha_app`: LOGIN, NOBYPASSRLS, ega EMAS.
#                        API'ning barcha oddiy so'rovlari. RLS SHU rolga
#                        qo'llanadi — multi-tenant izolyatsiyasi shundan.
#   DATABASE_ADMIN_URL — owner (POSTGRES_USER): migratsiya, rol yaratish va
#                        `withBypass()` (super-admin paneli, vitrina slug
#                        qidiruvi). RLS'ni chetlab o'tadi.
#
# DIQQAT: DATABASE_URL'ni owner roliga qaytarmang — RLS jim o'chadi.
# Prod'da DATABASE_ADMIN_URL majburiy (yo'q bo'lsa API ishga tushmaydi).
DATABASE_URL=postgresql://murcha_app:murcha_app@postgres:5432/murcha?schema=public
DATABASE_ADMIN_URL=postgresql://murcha:murcha@postgres:5432/murcha?schema=public

# `prisma/setup-roles.js` (pnpm db:roles) shu ikkisidan `murcha_app` rolini
# yaratadi/parolini yangilaydi — DATABASE_URL'dagi qiymatlar bilan MOS bo'lsin.
APP_DB_USER=murcha_app
APP_DB_PASSWORD=murcha_app

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- MinIO (S3-compatible) ---
MINIO_ROOT_USER=murcha
MINIO_ROOT_PASSWORD=murcha123
MINIO_BUCKET=murcha
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- API ---
API_PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# --- Auth (Faza 1) ---
# Kamida 32 belgili tasodifiy satr: openssl rand -hex 32
JWT_ACCESS_SECRET=dev-only-change-me
JWT_ACCESS_EXPIRES_IN=15m
# Refresh token cookie — production'da .murcha.uz (app./shop. subdomenlar uchun umumiy)
COOKIE_DOMAIN=
REFRESH_TOKEN_TTL_DAYS=30

# --- Sentry (ixtiyoriy — bo'sh bo'lsa o'chiq, self-hosted GlitchTip ham shu DSN) ---
SENTRY_DSN=

# --- SMS (Eskiz.uz, ixtiyoriy — bo'sh bo'lsa SMS yuborilmaydi, faqat logga yoziladi) ---
ESKIZ_BASE_URL=https://notify.eskiz.uz/api
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
ESKIZ_SMS_FROM=4546

# --- Ilova domenlari (SMS/taklif havolalari uchun) ---
APP_WEB_URL=https://app.murcha.uz
APP_SHOP_URL=https://shop.murcha.uz

# --- Web Push (ixtiyoriy — bo'sh bo'lsa push yuborilmaydi, faqat logga yoziladi) ---
# Kalitlarni generatsiya qilish: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@murcha.uz
# apps/web frontend'da PushManager.subscribe() uchun (VAPID_PUBLIC_KEY bilan bir xil qiymat).
# DIQQAT: Vite `VITE_*`ni BUILD VAQTIDA qotiradi — prod'da konteyner env'iga
# qo'yish KECH. `apps/web` image'i uchun u GitHub Actions repo *variable*'idan
# build-arg sifatida uzatiladi (`deploy.yml`), bu yerdagi qiymat faqat lokal
# `pnpm dev`/`pnpm build` uchun.
VITE_VAPID_PUBLIC_KEY=

# =========================================================================
# PROD DEPLOY (faqat docker-compose.prod.yml — Faza 12/13)
# =========================================================================
# Prod serverdagi `.env` shu bo'limni TO'LDIRISHI SHART. Quyidagilar
# sozlanmasa `docker compose -f docker-compose.prod.yml up` umuman ishga
# tushmaydi (`:?` bilan majburiy qilingan) — bu ataylab: standart parol
# bilan jimgina prod'ga chiqib ketmaslik uchun.
#
#   POSTGRES_PASSWORD      — yuqoridagi standart `murcha` PROD'DA ISHLAMAYDI
#   MINIO_ROOT_PASSWORD    — standart `murcha123` PROD'DA ISHLAMAYDI
#   GHCR_IMAGE_PREFIX      — quyida
#
# Bundan tashqari API o'zi tekshiradi (`src/config/env.js`) va standart
# `dev-only-change-me` yoki 32 belgidan qisqa qiymat bilan ishga tushmaydi:
#   JWT_ACCESS_SECRET      — yangi qiymat: openssl rand -hex 32
#
# Yangi parol/sir generatsiya qilish:
#   openssl rand -hex 32
#
# .github/workflows/deploy.yml GHCR'ga shu prefiks bilan push qiladi:
# ghcr.io/<github-owner>/<repo> — kichik harflarda (GHCR katta harfni
# qabul qilmaydi). Bu repo uchun: ghcr.io/hamidullo/murcha
GHCR_IMAGE_PREFIX=
